[configuration]

entry_symbol = "gdrpg_library_init"
compatibility_minimum = "4.2"
reloadable = true

[libraries]

linux.debug.x86_64 = "res://bin/libgdrpg.so"
linux.release.x86_64 = "res://bin/libgdrpg.so"
windows.debug.x86_64 = "res://bin/gdrpg.dll"
windows.release.x86_64 = "res://bin/gdrpg.dll"
macos.debug = "res://bin/libgdrpg.dylib"
macos.release = "res://bin/libgdrpg.dylib"
